generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  clients  Client[]
  tenant   Tenant?  @relation(fields: [tenantId], references: [id])
  tenantId String?
}

model Client {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  status    String   @default("lead") 
  createdAt DateTime @default(now())

  userId   String
  user     User    @relation(fields: [userId], references: [id])
  tenant   Tenant? @relation(fields: [tenantId], references: [id])
  tenantId String?
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  users     User[]
  clients   Client[]
  createdAt DateTime @default(now())
}
